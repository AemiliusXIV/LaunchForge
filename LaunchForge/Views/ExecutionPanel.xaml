<UserControl x:Class="LaunchForge.Views.ExecutionPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
            BorderThickness="0,1,0,0" Background="#F8F8F8">
        <StackPanel Margin="12,8">

            <!-- Status row -->
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="■  Cancel" Width="90"
                        Command="{Binding CancelCommand}"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
            </DockPanel>

            <!-- Progress bar -->
            <ProgressBar Height="6" Margin="0,6,0,0"
                         Value="{Binding Progress}"
                         Maximum="1"
                         IsIndeterminate="{Binding CurrentStepIndex, Converter={StaticResource NegToTrue}}"/>

            <!-- Log -->
            <TextBox Margin="0,6,0,0"
                     Height="80"
                     Text="{Binding Log, Mode=OneWay}"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Courier New"
                     FontSize="11"
                     TextChanged="Log_TextChanged"/>
        </StackPanel>
    </Border>
</UserControl>
