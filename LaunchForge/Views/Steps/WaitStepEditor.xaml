<UserControl x:Class="LaunchForge.Views.Steps.WaitStepEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="12" DataContext="{Binding}">

        <TextBlock Text="Wait duration (seconds)" Style="{StaticResource FieldLabel}"/>
        <DockPanel>
            <TextBlock DockPanel.Dock="Right" Text="seconds" VerticalAlignment="Center" Margin="6,0,0,0"/>
            <Slider Minimum="1" Maximum="300" SmallChange="1" LargeChange="10" TickFrequency="10"
                    TickPlacement="BottomRight" IsSnapToTickEnabled="False"
                    Value="{Binding Seconds}"/>
        </DockPanel>
        <TextBox Text="{Binding Seconds, UpdateSourceTrigger=PropertyChanged}"
                 Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"/>

        <TextBlock Text="Label (optional note)" Margin="0,14,0,2" Style="{StaticResource FieldLabel}"/>
        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"/>

        <CheckBox Margin="0,10,0,0" Content="Step enabled"
                  IsChecked="{Binding IsEnabled}"/>
    </StackPanel>
</UserControl>
