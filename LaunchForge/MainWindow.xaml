<Window x:Class="LaunchForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LaunchForge.ViewModels"
        xmlns:views="clr-namespace:LaunchForge.Views"
        Title="{Binding WindowTitle}"
        Width="900" Height="640"
        MinWidth="700" MinHeight="450">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- toolbar -->
            <RowDefinition Height="*"/>      <!-- main area -->
            <RowDefinition Height="Auto"/>   <!-- execution panel -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True">

            <!-- File group -->
            <Button Content="New" Command="{Binding NewSequenceCommand}" ToolTip="New sequence"/>
            <Button Content="Open" Command="{Binding OpenSequenceCommand}" ToolTip="Open .lfjson"/>
            <Button Content="Save" Command="{Binding SaveSequenceCommand}" ToolTip="Save"/>
            <Button Content="Save As" Command="{Binding SaveSequenceAsCommand}" ToolTip="Save As…"/>

            <Separator/>

            <!-- Sequence name inline edit -->
            <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox Width="180" Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center"/>

            <Separator/>

            <!-- Export -->
            <Button Content="Export .bat" Command="{Binding ExportBatCommand}" ToolTip="Export as batch script"/>
            <Button Content="Export .ps1" Command="{Binding ExportPs1Command}" ToolTip="Export as PowerShell script"/>

            <Separator/>

            <!-- Run -->
            <Button Content="▶  Run" Command="{Binding RunSequenceCommand}"
                    FontWeight="SemiBold"
                    ToolTip="Run sequence directly"/>
        </ToolBar>

        <!-- ── Main area: step list + editor ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="160"/>
                <ColumnDefinition Width="4"/>   <!-- splitter -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Step list -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Steps}"
                         SelectedItem="{Binding SelectedStep}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Opacity="{Binding IsEnabled, Converter={StaticResource BoolToOpacity}}">
                                <Border Style="{StaticResource TypeTag}">
                                    <TextBlock Text="{Binding TypeTag}" FontSize="10" FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="{Binding Summary}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Step list buttons -->
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="4">
                    <Button Content="▲" Width="28" Margin="2"
                            Command="{Binding MoveStepUpCommand}"
                            CommandParameter="{Binding SelectedStep}"
                            ToolTip="Move up"/>
                    <Button Content="▼" Width="28" Margin="2"
                            Command="{Binding MoveStepDownCommand}"
                            CommandParameter="{Binding SelectedStep}"
                            ToolTip="Move down"/>
                    <Button Content="✕" Width="28" Margin="2"
                            Command="{Binding RemoveStepCommand}"
                            CommandParameter="{Binding SelectedStep}"
                            ToolTip="Remove step"/>

                    <!-- Add step dropdown -->
                    <Button Content="+" Width="28" Margin="2" ToolTip="Add step"
                            Click="AddStep_Click" x:Name="AddStepButton"/>
                    <Popup x:Name="AddStepPopup" StaysOpen="False"
                           PlacementTarget="{Binding ElementName=AddStepButton}">
                        <Border Background="White" BorderBrush="#CCC" BorderThickness="1">
                            <StackPanel>
                                <Button Content="Launch App"             Tag="LaunchApp"            Click="AddStepMenu_Click" Style="{StaticResource MenuButton}"/>
                                <Button Content="Launch Steam Game"      Tag="LaunchSteam"           Click="AddStepMenu_Click" Style="{StaticResource MenuButton}"/>
                                <Button Content="Wait"                   Tag="Wait"                  Click="AddStepMenu_Click" Style="{StaticResource MenuButton}"/>
                                <Button Content="Kill Process"           Tag="KillProcess"           Click="AddStepMenu_Click" Style="{StaticResource MenuButton}"/>
                                <Button Content="Wait for Process Start" Tag="WaitForProcessStart"   Click="AddStepMenu_Click" Style="{StaticResource MenuButton}"/>
                                <Button Content="Wait for Process Exit"  Tag="WaitForProcessExit"    Click="AddStepMenu_Click" Style="{StaticResource MenuButton}"/>
                                <Button Content="Run PowerShell"         Tag="RunPowerShell"         Click="AddStepMenu_Click" Style="{StaticResource MenuButton}"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </WrapPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Step editor panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding SelectedStep}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <Trigger Property="Content" Value="{x:Null}">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBlock Text="Select a step to edit it, or click + to add one."
                                                           Foreground="Gray" Margin="20"
                                                           FontStyle="Italic" VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </ScrollViewer>
        </Grid>

        <!-- ── Execution panel (shown when running) ── -->
        <views:ExecutionPanel Grid.Row="2"
                              DataContext="{Binding Execution}"
                              Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}"/>
    </Grid>
</Window>
