<Application x:Class="LaunchForge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LaunchForge.ViewModels.Steps"
             xmlns:views="clr-namespace:LaunchForge.Views.Steps"
             xmlns:conv="clr-namespace:LaunchForge.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ── Value converters ── -->
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToOpacityConverter   x:Key="BoolToOpacity"/>
        <conv:InvertBoolConverter      x:Key="InvertBool"/>
        <conv:NotNullConverter         x:Key="NotNull"/>
        <conv:NegativeToTrueConverter  x:Key="NegToTrue"/>

        <!-- Inline converters as StaticResources for converters not in the BCL -->

        <!-- ── Shared styles ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>

        <Style x:Key="TypeTag" TargetType="Border">
            <Setter Property="CornerRadius"   Value="3"/>
            <Setter Property="Padding"        Value="4,1"/>
            <Setter Property="Background"     Value="#E3F2FD"/>
            <Setter Property="Margin"         Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ── MenuButton style for the add-step popup ── -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                    Value="12,6"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="MinWidth"                   Value="200"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Implicit DataTemplates: map each step VM to its editor ── -->
        <DataTemplate DataType="{x:Type vm:LaunchAppStepViewModel}">
            <views:LaunchAppStepEditor/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LaunchSteamStepViewModel}">
            <views:LaunchSteamStepEditor/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WaitStepViewModel}">
            <views:WaitStepEditor/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:KillProcessStepViewModel}">
            <views:KillProcessStepEditor/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WaitForProcessStartStepViewModel}">
            <views:WaitForProcessStartStepEditor/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WaitForProcessExitStepViewModel}">
            <views:WaitForProcessExitStepEditor/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RunPowerShellStepViewModel}">
            <views:RunPowerShellStepEditor/>
        </DataTemplate>

    </Application.Resources>
</Application>
