<UserControl x:Class="LaunchForge.Views.Steps.LaunchSteamStepEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="12" DataContext="{Binding}">

        <TextBlock Text="Steam App ID" Style="{StaticResource FieldLabel}"/>
        <DockPanel>
            <Button DockPanel.Dock="Right" Content="Pick Game…" Margin="4,0,0,0"
                    Click="PickGame_Click"/>
            <TextBox Text="{Binding AppId, UpdateSourceTrigger=PropertyChanged}"/>
        </DockPanel>

        <TextBlock Text="Game name (display only)" Margin="0,10,0,2" Style="{StaticResource FieldLabel}"/>
        <TextBox Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Margin="0,6,0,0" Foreground="Gray" FontSize="11"
                   Text="The game name is stored for display purposes only. The App ID is what the script uses."/>

        <TextBlock Text="Label (optional note)" Margin="0,14,0,2" Style="{StaticResource FieldLabel}"/>
        <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"/>

        <CheckBox Margin="0,10,0,0" Content="Step enabled"
                  IsChecked="{Binding IsEnabled}"/>
    </StackPanel>
</UserControl>
